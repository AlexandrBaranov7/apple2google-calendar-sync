<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <key>Label</key>
    <string>com.user.calendarsync</string>

    <!--
        Option A (default): run the package directly via the venv interpreter.
        Option B: if the package is installed (`pip install -e .`), use the
                  console script instead and remove the two lines below it:
                      <string>/Users/baranov.am/.venv/calendarsync/bin/apple2google-sync</string>
    -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/baranov.am/.venv/calendarsync/bin/python3</string>
        <string>-m</string>
        <string>apple2google_calendar_sync</string>
    </array>

    <!-- Working directory must contain the top-level config.py -->
    <key>WorkingDirectory</key>
    <string>/Users/baranov.am/Applications/CalendarSync</string>

    <!-- Run every 15 minutes (900 seconds) -->
    <key>StartInterval</key>
    <integer>900</integer>

    <!-- Also run immediately when the agent is loaded -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Logs – rotate manually or via newsyslog if needed -->
    <key>StandardOutPath</key>
    <string>/Users/baranov.am/Library/Logs/CalendarSync/sync.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/baranov.am/Library/Logs/CalendarSync/sync_error.log</string>

    <!--
        Propagate the user's PATH so the interpreter and any helpers are found.
        Adjust HOME if you run as a different user.
    -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/baranov.am</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

</dict>
</plist>
